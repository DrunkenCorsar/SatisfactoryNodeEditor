<Window x:Class="SatisfactoryNodeEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:SatisfactoryNodeEditor.App.Controls"
        mc:Ignorable="d"
        Title="{Binding WindowTitle, Mode=OneWay, FallbackValue=Satisfactory Node Editor v0.1.1}"
        Icon="Assets/Brand/app-icon.ico"
        WindowState="Maximized"
        MinHeight="760"
        MinWidth="1180"
        Background="{DynamicResource AppWindowBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="LinkButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource WindowsAccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BoxedToggleCheckBox" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Box"
                                        Width="16"
                                        Height="16"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1.5"
                                        Background="{DynamicResource AppPanelBrush}"
                                        CornerRadius="3"
                                        VerticalAlignment="Center">
                                    <Path x:Name="Check"
                                          Data="M 3,8 L 6.3,11.2 L 13,4"
                                          Stroke="{DynamicResource WindowsAccentTextBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource WindowsAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource WindowsAccentBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource WindowsAccentBrush}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditorTabButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="3" />
                                </Grid.RowDefinitions>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                                <Border Grid.Row="1"
                                        x:Name="SelectedUnderline"
                                        Background="{TemplateBinding Foreground}"
                                        Opacity="0.65"
                                        CornerRadius="2,2,0,0"
                                        Margin="12,0"
                                        Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource WindowsAccentBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="SelectedUnderline" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Control x:Name="InitialFocusSink"
                 Width="0"
                 Height="0"
                 Focusable="True"
                 IsHitTestVisible="False"
                 IsTabStop="False" />

        <Button Grid.RowSpan="2"
                Content="Support"
                Command="{Binding SupportCommand}"
                Padding="12,6"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Visibility="{Binding IsWelcomeVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <StackPanel Grid.RowSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsWelcomeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="560"
                    Style="{StaticResource PanelBorder}"
                    Padding="44"
                    AllowDrop="True"
                    DragOver="WelcomeDropZone_DragOver"
                    Drop="WelcomeDropZone_Drop">
                <StackPanel HorizontalAlignment="Stretch">
                    <Image Source="Assets/Brand/app-logo.png"
                           Width="78"
                           Height="78"
                           Margin="0,0,0,18"
                           SnapsToDevicePixels="False"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           RenderOptions.EdgeMode="Unspecified" />
                    <TextBlock Text="Upload your save file"
                               FontSize="28"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Drop a Satisfactory .sav file here, or choose one manually."
                               Style="{StaticResource SecondaryText}"
                               FontSize="15"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,28" />
                    <Border BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="34"
                            Margin="0,0,0,24"
                            Background="{DynamicResource AppInputBrush}">
                        <StackPanel>
                            <TextBlock Text=".sav"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Drag and drop your save file"
                                       Style="{StaticResource MutedText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Button Content="Choose .sav file"
                            Command="{Binding ReadSaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="180"
                            HorizontalAlignment="Center" />
                    <TextBlock Margin="0,16,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap">
                        <Run Text="Don't have a save? No worries: " />
                        <InlineUIContainer BaselineAlignment="Center">
                            <Button Command="{Binding UseTemplateCommand}"
                                    Style="{StaticResource LinkButton}">
                                <TextBlock Text="Use our template"
                                           Foreground="{DynamicResource WindowsAccentBrush}"
                                           TextDecorations="Underline"
                                           FontWeight="SemiBold" />
                            </Button>
                        </InlineUIContainer>
                        <Run Text=" for a quick start." />
                    </TextBlock>
                    <Border Margin="0,22,0,0"
                            Padding="14"
                            CornerRadius="7"
                            BorderThickness="1"
                            BorderBrush="#8F5F1E1E"
                            Background="#33B64040"
                            Visibility="{Binding HasLoadError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding LoadErrorMessage}"
                                       Foreground="#FFFFCFCF"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Command="{Binding CopyLogsCommand}"
                                        Style="{StaticResource LinkButton}"
                                        Margin="0,0,14,0">
                                    <TextBlock Text="Copy logs"
                                               Foreground="#FF8FD8FF"
                                               TextDecorations="Underline"
                                               FontWeight="SemiBold" />
                                </Button>
                                <Button Command="{Binding ToggleCompatibilityGuideCommand}"
                                        Style="{StaticResource LinkButton}">
                                    <TextBlock Text="I'm sorry, what?"
                                               Foreground="#FF8FD8FF"
                                               TextDecorations="Underline"
                                               FontWeight="SemiBold" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Width="560"
                    Style="{StaticResource PanelBorder}"
                    Padding="24"
                    Margin="18,0,0,0"
                    Visibility="{Binding IsCompatibilityGuideVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="How to make a compatible save"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="This tool edits the resource and purity values that Satisfactory writes only when node randomization is enabled. The setting does not disable achievements."
                                   Style="{StaticResource SecondaryText}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="1. Start creating a new game and open Game Modes."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Background="{DynamicResource AppInputBrush}"
                                Margin="0,0,0,16"
                                ClipToBounds="True">
                            <Button Command="{Binding ToggleGuideImageCommand}"
                                    CommandParameter="Assets/Guide/new-game-game-modes.png"
                                    Style="{StaticResource LinkButton}"
                                    HorizontalContentAlignment="Stretch">
                                <Image Source="Assets/Guide/new-game-game-modes.png"
                                       Stretch="Uniform"
                                       MaxHeight="180"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Unspecified" />
                            </Button>
                        </Border>
                        <TextBlock Text="2. In World Randomization, set Resource Node Randomization to Random and Resource Node Purity to Random."
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Background="{DynamicResource AppInputBrush}"
                                Margin="0,0,0,16"
                                ClipToBounds="True">
                            <Button Command="{Binding ToggleGuideImageCommand}"
                                    CommandParameter="Assets/Guide/world-randomization.png"
                                    Style="{StaticResource LinkButton}"
                                    HorizontalContentAlignment="Stretch">
                                <Image Source="Assets/Guide/world-randomization.png"
                                       Stretch="Uniform"
                                       MaxHeight="150"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       RenderOptions.EdgeMode="Unspecified" />
                            </Button>
                        </Border>
                        <TextBlock Text="Anything other than Default may also serialize compatible node data, but Random is the tested option. Create the world, save it, then load that .sav file here."
                                   Style="{StaticResource SecondaryText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <Border Grid.RowSpan="2"
                Background="#D9000000"
                Padding="28"
                Panel.ZIndex="10"
                Visibility="{Binding IsGuideImageOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button Command="{Binding ToggleGuideImageCommand}"
                    CommandParameter="{Binding GuideImageOverlaySource}"
                    Style="{StaticResource LinkButton}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <Image Source="{Binding GuideImageOverlaySource}"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True" />
            </Button>
        </Border>

        <Border Grid.RowSpan="2"
                Background="#D9000000"
                Padding="28"
                Panel.ZIndex="20"
                Visibility="{Binding IsSafetyNoticeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource PanelBorder}"
                    Width="560"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <Image Source="Assets/Brand/app-logo.png"
                           Width="58"
                           Height="58"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,16"
                           SnapsToDevicePixels="False"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           RenderOptions.EdgeMode="Unspecified" />
                    <TextBlock Text="Before you edit a save"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <TextBlock Text="Satisfactory Node Editor is an experimental, unofficial save editing tool for Satisfactory. It is not affiliated with Coffee Stain Studios."
                               TextWrapping="Wrap"
                               FontSize="14"
                               Margin="0,0,0,12" />
                    <Border Padding="14"
                            CornerRadius="7"
                            BorderThickness="1"
                            BorderBrush="#8F8A5A00"
                            Background="#33D49A2A"
                            Margin="0,0,0,16">
                        <TextBlock Text="Always back up your saves before editing. The app creates a backup before writing, but keeping your own backups is still the safest way to protect important worlds."
                                   TextWrapping="Wrap"
                                   Style="{StaticResource SecondaryText}" />
                    </Border>
                    <Button Content="Continue"
                            Command="{Binding AcceptSafetyNoticeCommand}"
                            Style="{StaticResource PrimaryButton}"
                            MinWidth="150"
                            HorizontalAlignment="Right" />
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorder}"
                Padding="12"
                Margin="0,0,0,12"
                Visibility="{Binding HasLoadedSave, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0"
                        Grid.Column="0"
                        Content="Read .sav file"
                        Command="{Binding ReadSaveCommand}"
                        Margin="0,0,12,0" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="Selected file:"
                           Style="{StaticResource SecondaryText}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="{Binding InputSaveFileName}"
                           ToolTip="{Binding InputSavePath}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />

                <Button Grid.Row="0"
                        Grid.Column="3"
                        Content="Save .sav file as..."
                        Command="{Binding SaveCommand}"
                        Margin="20,0,12,0" />
                <TextBlock Grid.Row="0"
                           Grid.Column="4"
                           Text="Output file:"
                           Style="{StaticResource SecondaryText}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Grid.Row="0"
                           Grid.Column="5"
                           Text="{Binding OutputSaveFileName}"
                           ToolTip="{Binding OutputSavePath}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <Button Grid.Row="0"
                        Grid.Column="6"
                        Content="Open output directory"
                        Command="{Binding OpenOutputCommand}"
                        Margin="20,0,0,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Visibility="{Binding HasLoadedSave, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,14">
                        <Button Content="Shuffle"
                                Command="{Binding SetEditorTabCommand}"
                                CommandParameter="Shuffle"
                                Style="{StaticResource EditorTabButton}"
                                Tag="{Binding IsShuffleTabSelected}"
                                Background="{Binding ShuffleTabBrush}"
                                Foreground="{Binding ShuffleTabTextBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                FontWeight="SemiBold"
                                Margin="0,0,6,0" />
                        <Button Content="Map Brush"
                                Command="{Binding SetEditorTabCommand}"
                                CommandParameter="MapBrush"
                                Style="{StaticResource EditorTabButton}"
                                Tag="{Binding IsMapBrushTabSelected}"
                                Background="{Binding MapBrushTabBrush}"
                                Foreground="{Binding MapBrushTabTextBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                FontWeight="SemiBold"
                                Margin="0,0,6,0" />
                        <Button Content="About"
                                Command="{Binding SetEditorTabCommand}"
                                CommandParameter="About"
                                Style="{StaticResource EditorTabButton}"
                                Tag="{Binding IsAboutTabSelected}"
                                Background="{Binding AboutTabBrush}"
                                Foreground="{Binding AboutTabTextBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                FontWeight="SemiBold" />
                    </UniformGrid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsShuffleTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Border Style="{StaticResource PanelBorder}" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Clustering" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                                    <TextBlock Text="Controls how strongly the shuffle groups matching resources together. Lower values keep resources more mixed across the map; higher values form tighter resource regions."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12" />
                                    <TextBlock Text="{Binding ClusteringDisplay}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,0,6" />
                                    <Slider Minimum="0" Maximum="100" Value="{Binding ClusteringValue}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}"
                                    Padding="12"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding IsHardModeAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Hard Mode" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" />
                                    <CheckBox Content="Enable Hard Mode"
                                              IsChecked="{Binding IsHardModeEnabled}"
                                              Style="{StaticResource BoxedToggleCheckBox}" />
                                    <TextBlock Text="Places Iron, Copper, and Limestone clusters as far apart as possible."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="24,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}" Padding="12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Resource Counts" FontWeight="SemiBold" FontSize="16" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TotalNodesDisplay}"
                                                   Foreground="{Binding TotalNodesBrush}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding ResourceCounts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="26" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="58" />
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="54" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="16"
                                                             Height="16"
                                                             Stroke="{DynamicResource AppBorderBrush}"
                                                             StrokeThickness="1.5"
                                                             Fill="{Binding ColorHex}"
                                                             VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Style="{StaticResource SecondaryText}" />
                                                        <TextBlock Text="{Binding DefaultCount, StringFormat= ({0})}"
                                                                   Style="{StaticResource MutedText}"
                                                                   Margin="4,0,0,0"
                                                                   Visibility="{Binding DataContext.ShowDefaultResourceCounts, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </StackPanel>
                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                                             Height="28"
                                                             HorizontalContentAlignment="Right"
                                                             VerticalContentAlignment="Center"
                                                             Margin="8,0" />
                                                    <Button Grid.Column="3"
                                                            Content="-"
                                                            Command="{Binding DataContext.DecrementResourceCountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Width="24"
                                                            Height="28"
                                                            Padding="0"
                                                            Margin="0,0,2,0" />
                                                    <Button Grid.Column="4"
                                                            Content="+"
                                                            Command="{Binding DataContext.IncrementResourceCountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Width="24"
                                                            Height="28"
                                                            Padding="0"
                                                            Margin="0,0,6,0" />
                                                    <TextBlock Grid.Column="5"
                                                               Text="{Binding Percentage, StringFormat={}{0:0.0}%}"
                                                               Style="{StaticResource MutedText}"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="Reset to Initial"
                                                Command="{Binding ResetInitialResourceCountsCommand}"
                                                Visibility="{Binding ShouldShowInitialResetButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Margin="0,0,8,0" />
                                        <Button Grid.Column="1"
                                                Content="Reset to Default"
                                                Command="{Binding ResetResourceCountsCommand}" />
                                        <CheckBox Grid.Column="3"
                                                  Content="Show defaults"
                                                  IsChecked="{Binding ShowDefaultResourceCounts}"
                                                  Style="{StaticResource BoxedToggleCheckBox}"
                                                  Margin="10,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}" Padding="12" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="Purity Distribution" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" />
                                    <TextBlock Text="Mode" Style="{StaticResource SecondaryText}" Margin="0,0,0,6" />
                                    <UniformGrid Columns="3" Margin="0,0,0,10">
                                        <Button Content="Native"
                                                Command="{Binding SetPurityDistributionModeCommand}"
                                                CommandParameter="Native"
                                                Background="{Binding NativeModeButtonBrush}"
                                                Foreground="{Binding NativeModeTextBrush}"
                                                Padding="8,7"
                                                Margin="0,0,6,0" />
                                        <Button Content="Global"
                                                Command="{Binding SetPurityDistributionModeCommand}"
                                                CommandParameter="Global"
                                                Background="{Binding GlobalModeButtonBrush}"
                                                Foreground="{Binding GlobalModeTextBrush}"
                                                Padding="8,7"
                                                Margin="0,0,6,0" />
                                        <Button Content="Per Resource"
                                                Command="{Binding SetPurityDistributionModeCommand}"
                                                CommandParameter="PerResource"
                                                Background="{Binding PerResourceModeButtonBrush}"
                                                Foreground="{Binding PerResourceModeTextBrush}"
                                                Padding="8,7" />
                                    </UniformGrid>

                                    <Button Content="Shuffle Purities Only"
                                            Command="{Binding ShufflePuritiesCommand}"
                                            Margin="0,0,0,12"
                                            HorizontalAlignment="Stretch" />

                                    <TextBlock Text="Uses the native purity distribution from the save file."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding IsNativePurityMode, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <StackPanel Visibility="{Binding IsGlobalPurityMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <controls:ThreeWayPuritySlider ImpurePercent="{Binding GlobalPurityDistribution.ImpurePercent, Mode=TwoWay}"
                                                                       NormalPercent="{Binding GlobalPurityDistribution.NormalPercent, Mode=TwoWay}"
                                                                       PurePercent="{Binding GlobalPurityDistribution.PurePercent, Mode=TwoWay}"
                                                                       Margin="0,2,0,10" />
                                        <Border Background="{DynamicResource AppInputBrush}"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="56" />
                                                    <ColumnDefinition Width="74" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Impure" Foreground="#d64545" />
                                                <TextBlock Grid.Column="1" Text="{Binding GlobalPurityDistribution.ImpurePercent, StringFormat={}{0:0}%}" TextAlignment="Right" />
                                                <TextBlock Grid.Column="2" Text="{Binding GlobalPurityDistribution.ImpureNodeCount, StringFormat={}{0} nodes}" Style="{StaticResource MutedText}" TextAlignment="Right" />
                                                <TextBlock Grid.Row="1" Text="Normal" Foreground="#e59b35" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GlobalPurityDistribution.NormalPercent, StringFormat={}{0:0}%}" TextAlignment="Right" />
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding GlobalPurityDistribution.NormalNodeCount, StringFormat={}{0} nodes}" Style="{StaticResource MutedText}" TextAlignment="Right" />
                                                <TextBlock Grid.Row="2" Text="Pure" Foreground="#3bb35d" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GlobalPurityDistribution.PurePercent, StringFormat={}{0:0}%}" TextAlignment="Right" />
                                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding GlobalPurityDistribution.PureNodeCount, StringFormat={}{0} nodes}" Style="{StaticResource MutedText}" TextAlignment="Right" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1"
                          Visibility="{Binding IsMapBrushTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <Border Style="{StaticResource PanelBorder}" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Brush Controls" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" />
                                    <TextBlock Text="Hold Ctrl to activate the brush. LMB paints ordinary resource nodes inside the brush circle; RMB marks them Empty for removal from the final save. Middle-click a node to pick its resource and purity into the brush."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Resource" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                                    <CheckBox Content="Change resources"
                                              IsChecked="{Binding IsBrushResourceChangeEnabled}"
                                              Style="{StaticResource BoxedToggleCheckBox}"
                                              Margin="0,0,0,10" />
                                    <ComboBox SelectedValue="{Binding BrushResourceType, Mode=TwoWay}"
                                              SelectedValuePath="Content"
                                              Visibility="{Binding IsBrushResourceChangeEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ComboBoxItem Content="Iron" />
                                        <ComboBoxItem Content="Limestone" />
                                        <ComboBoxItem Content="Coal" />
                                        <ComboBoxItem Content="Copper" />
                                        <ComboBoxItem Content="Crude Oil" />
                                        <ComboBoxItem Content="SAM" />
                                        <ComboBoxItem Content="Caterium" />
                                        <ComboBoxItem Content="Bauxite" />
                                        <ComboBoxItem Content="Raw Quartz" />
                                        <ComboBoxItem Content="Sulfur" />
                                        <ComboBoxItem Content="Uranium" />
                                        <ComboBoxItem Content="Empty" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Purity" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                                    <CheckBox Content="Change purity"
                                              IsChecked="{Binding IsBrushPurityChangeEnabled}"
                                              Style="{StaticResource BoxedToggleCheckBox}"
                                              Margin="0,0,0,10" />
                                    <ComboBox SelectedValue="{Binding BrushPurity, Mode=TwoWay}"
                                              SelectedValuePath="Content"
                                              Visibility="{Binding IsBrushPurityChangeEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ComboBoxItem Content="Impure" />
                                        <ComboBoxItem Content="Normal" />
                                        <ComboBoxItem Content="Pure" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}" Padding="12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Brush size" FontWeight="SemiBold" FontSize="16" />
                                        <TextBlock Grid.Column="1" Text="{Binding BrushSizeDisplay}" Style="{StaticResource SecondaryText}" />
                                    </Grid>
                                    <Slider Minimum="8" Maximum="128" Value="{Binding BrushSizePixels, Mode=TwoWay}" TickFrequency="8" IsSnapToTickEnabled="True" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Style="{StaticResource PanelBorder}"
                                Padding="14"
                                VerticalAlignment="Bottom">
                            <StackPanel>
                                <TextBlock Text="Important"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="The brush only changes ordinary resource nodes. It does not paint fracking wells, well satellites, or geysers. Resource shuffle function also doesn't affect these special nodes."
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Fracking wells can still be edited from their map card. Geysers are display-only because currently save files do not expose reliable mutable geyser purity data."
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsAboutTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Border Style="{StaticResource PanelBorder}" Padding="18" Margin="0,0,0,12">
                                <StackPanel HorizontalAlignment="Stretch">
                                    <Image Source="Assets/Brand/app-logo.png"
                                           Width="64"
                                           Height="64"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,14"
                                           SnapsToDevicePixels="False"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           RenderOptions.EdgeMode="Unspecified" />
                                    <TextBlock Text="Satisfactory Node Editor"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <TextBlock Style="{StaticResource SecondaryText}" FontSize="14" Margin="0,0,0,14">
                                        <Run Text="Version: " />
                                        <Run Text="{Binding AppVersion, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="Unofficial save editing tool for Satisfactory"
                                               TextWrapping="Wrap"
                                               FontSize="14"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Not affiliated with Coffee Stain Studios"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Links"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               Margin="0,0,0,10" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Discord"
                                                   Style="{StaticResource MutedText}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Command="{Binding SupportCommand}"
                                                Style="{StaticResource LinkButton}"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="https://discord.gg/w8hqmrmn5J"
                                                       Foreground="{DynamicResource WindowsAccentBrush}"
                                                       TextDecorations="Underline"
                                                       TextWrapping="Wrap" />
                                        </Button>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="GitHub"
                                                   Style="{StaticResource MutedText}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Command="{Binding OpenGitHubCommand}"
                                                Style="{StaticResource LinkButton}"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="DrunkenCorsar/SatisfactoryNodeEditor"
                                                       Foreground="{DynamicResource WindowsAccentBrush}"
                                                       TextDecorations="Underline"
                                                       TextWrapping="Wrap" />
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Padding="14"
                                    CornerRadius="7"
                                    BorderThickness="1"
                                    BorderBrush="#8F8A5A00"
                                    Background="#33D49A2A">
                                <StackPanel>
                                    <TextBlock Text="Backup warning"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="Always back up your saves before editing. This app writes a separate output save by default, but backups are still the safest way to protect your worlds."
                                               TextWrapping="Wrap"
                                               Style="{StaticResource SecondaryText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2"
                            Content="Shuffle"
                            Command="{Binding ShuffleCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Visibility="{Binding IsShuffleTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,14,0,0" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource PanelBorder}"
                    Width="340"
                    Padding="12"
                    Margin="0,0,12,0"
                    Visibility="{Binding IsPerResourcePurityPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Per Resource Purity" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PerResourcePurityDistributions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource AppInputBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="9"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Width="11"
                                                         Height="11"
                                                         Fill="{Binding ResourceBrush}"
                                                         Stroke="{DynamicResource AppBorderBrush}"
                                                         StrokeThickness="1"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ResourceName}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TotalNodeCount, StringFormat={}{0} nodes}"
                                                           Style="{StaticResource MutedText}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <controls:ThreeWayPuritySlider ImpurePercent="{Binding ImpurePercent, Mode=TwoWay}"
                                                                           NormalPercent="{Binding NormalPercent, Mode=TwoWay}"
                                                                           PurePercent="{Binding PurePercent, Mode=TwoWay}"
                                                                           Margin="0,0,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ImpurePercent, StringFormat=Impure {0:0}%}" Foreground="#d64545" FontSize="11" />
                                                <TextBlock Grid.Column="1" Text="{Binding NormalPercent, StringFormat=Normal {0:0}%}" Foreground="#e59b35" FontSize="11" TextAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="{Binding PurePercent, StringFormat=Pure {0:0}%}" Foreground="#3bb35d" FontSize="11" TextAlignment="Right" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="174" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorder}"
                        Padding="0"
                        ClipToBounds="True"
                        Margin="0,0,0,12">
                    <controls:MapViewport Nodes="{Binding ResourceNodes}"
                                          NodeEditedCommand="{Binding NodeEditedCommand}"
                                          IsBrushResourceChangeEnabled="{Binding IsBrushResourceChangeEnabled}"
                                          BrushResourceType="{Binding BrushResourceType}"
                                          IsBrushPurityChangeEnabled="{Binding IsBrushPurityChangeEnabled}"
                                          BrushPurity="{Binding BrushPurity}"
                                          BrushSizePixels="{Binding BrushSizePixels}" />
                </Border>

                <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Log"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="Copy Logs"
                                    Command="{Binding CopyLogsCommand}"
                                    Padding="10,5"
                                    Margin="0,0,8,0" />
                            <Button Grid.Column="2"
                                    Content="Clear Logs"
                                    Command="{Binding ClearLogCommand}"
                                    Padding="10,5"
                                    Margin="0,0,8,0" />
                            <Button Grid.Column="3"
                                    Content="Support"
                                    Command="{Binding SupportCommand}"
                                    Padding="10,5" />
                        </Grid>
                        <TextBox x:Name="LogTextBox"
                                 Grid.Row="1"
                                 Text="{Binding LogText, Mode=OneWay, NotifyOnTargetUpdated=True}"
                                 TargetUpdated="LogTextBox_TargetUpdated"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 Background="{DynamicResource AppInputBrush}"
                                 BorderBrush="{DynamicResource AppBorderBrush}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
