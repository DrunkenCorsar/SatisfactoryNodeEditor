<UserControl x:Class="SatisfactoryNodeEditor.App.Controls.ThreeWayPuritySlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="24">
    <Canvas x:Name="SliderCanvas"
            Height="24"
            SizeChanged="SliderCanvas_SizeChanged"
            MouseLeftButtonDown="SliderCanvas_MouseLeftButtonDown"
            MouseMove="SliderCanvas_MouseMove"
            MouseLeftButtonUp="SliderCanvas_MouseLeftButtonUp"
            MouseLeave="SliderCanvas_MouseLeftButtonUp">
        <Border x:Name="TrackBorder"
                Height="6"
                CornerRadius="3"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid x:Name="SegmentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ImpureColumn" Width="25*" />
                    <ColumnDefinition x:Name="NormalColumn" Width="50*" />
                    <ColumnDefinition x:Name="PureColumn" Width="25*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#9d3636" />
                <Border Grid.Column="1" Background="#b9792d" />
                <Border Grid.Column="2" Background="#2f8f4c" />
            </Grid>
        </Border>
        <Border x:Name="FirstHandle"
                Width="14"
                Height="14"
                CornerRadius="7"
                Background="{DynamicResource AppTextBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Cursor="SizeWE"
                MouseLeftButtonDown="FirstHandle_MouseLeftButtonDown" />
        <Border x:Name="SecondHandle"
                Width="14"
                Height="14"
                CornerRadius="7"
                Background="{DynamicResource AppTextBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Cursor="SizeWE"
                MouseLeftButtonDown="SecondHandle_MouseLeftButtonDown" />
    </Canvas>
</UserControl>
